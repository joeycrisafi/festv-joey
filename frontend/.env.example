# Backend API URL (leave empty for local development with proxy)
VITE_API_URL=

# For production, set to your deployed backend URL:
# VITE_API_URL=https://caterease-api.onrender.com

# Comma-separated emails that can access the /planner page
# VITE_PLANNER_EMAILS=you@example.com,partner@example.com

# Dev-only: shows TestAccountsPicker on the Login page.
# Also requires ENABLE_TEST_ACCOUNTS=true on the backend.
# NEVER set to true in production.
VITE_TEST_ACCOUNTS_ENABLED=false

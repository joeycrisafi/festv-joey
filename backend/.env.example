# Database
DATABASE_URL=postgresql://user:password@localhost:5432/caterease

# JWT Secrets (generate random strings for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Server
NODE_ENV=development
PORT=5000

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Admin Dashboard — comma-separated emails that can access /admin routes
# ADMIN_EMAILS=you@example.com,partner@example.com

# Discord Webhook URL for event notifications (get from Discord Server Settings > Integrations > Webhooks)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Email for critical event alerts (requires SMTP config above)
# ADMIN_NOTIFICATION_EMAIL=you@example.com

# Dev-only: enables POST /auth/seed-test-accounts and the TestAccountsPicker.
# NEVER set to true in production.
ENABLE_TEST_ACCOUNTS=false

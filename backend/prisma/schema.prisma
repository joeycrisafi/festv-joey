// FESTV Database Schema
// Event Planning & Service Provider Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  CLIENT
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  passwordHash         String
  role                 UserRole           @default(CLIENT)
  roles                UserRole[]         @default([CLIENT])
  status               UserStatus         @default(PENDING_VERIFICATION)
  emailVerified        Boolean            @default(false)
  phoneNumber          String?
  phoneVerified        Boolean            @default(false)

  // Profile info
  firstName            String
  lastName             String
  avatarUrl            String?
  bannerUrl            String?

  // Location
  address              String?
  city                 String?
  state                String?
  zipCode              String?
  country              String             @default("US")
  latitude             Float?
  longitude            Float?

  // Timestamps
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  lastLoginAt          DateTime?

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Relations
  providerProfiles     ProviderProfile[]
  eventRequests        EventRequest[]     @relation("ClientRequests")
  bookingsAsClient     Booking[]          @relation("ClientBookings")
  reviewsGiven         Review[]           @relation("ReviewAuthor")
  reviewsReceived      Review[]           @relation("ReviewSubject")
  sentMessages         Message[]          @relation("MessageSender")
  receivedMessages     Message[]          @relation("MessageRecipient")
  notifications        Notification[]
  favorites            Favorite[]
  refreshTokens        RefreshToken[]
  verificationCodes    VerificationCode[]
  events               Event[]

  @@index([email])
  @@index([role])
  @@index([city, state])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'email' or 'phone'
  code      String   // 6-digit code
  target    String   // email address or phone number
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([code, expiresAt])
}

// ============================================
// PROVIDER PROFILES
// ============================================

enum ProviderType {
  RESTO_VENUE
  CATERER
  ENTERTAINMENT
  PHOTO_VIDEO
  FLORIST_DECOR
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model ProviderProfile {
  id                       String             @id @default(uuid())
  userId                   String             // Removed @unique — user can have multiple profiles
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info
  businessName             String
  businessDescription      String?            @db.Text
  tagline                  String?
  websiteUrl               String?
  instagramHandle          String?
  yearsInBusiness          Int?
  languages                String[]           @default([])
  providerTypes            ProviderType[]
  primaryType              ProviderType?

  // Images
  bannerImageUrl           String?
  logoUrl                  String?

  // Solo worker vs Company
  isSoloWorker             Boolean            @default(false)

  // Verification
  verificationStatus       VerificationStatus @default(UNVERIFIED)
  verifiedAt               DateTime?
  licenseNumber            String?
  insuranceInfo            String?

  // Service area
  serviceRadius            Int                @default(50)
  travelOutsideRegion      Boolean            @default(false)
  serviceAreas             String[]

  // Per-person pricing
  minimumBudget            Float?
  maximumBudget            Float?
  pricePerPerson           Float?
  depositPercentage        Float              @default(25)

  // Hourly pricing
  hourlyRate               Float?
  minimumHours             Int?               @default(2)
  fixedFee                 Float?             @default(0)

  // Capabilities
  minGuestCount            Int                @default(10)
  maxGuestCount            Int                @default(500)

  // ── Step 2 type-specific fields ──

  // RESTO_VENUE
  seatedCapacity           Int?
  standingCapacity         Int?
  venueCuisine             String?
  venueIndoorOutdoor       String?
  avTechAvailable          Boolean            @default(false)
  dietaryOptions           String[]           @default([])

  // CATERER
  equipmentRentalAvailable Boolean            @default(false)
  caterSetupIncluded       Boolean            @default(false)

  // ENTERTAINMENT
  genreTags                String[]           @default([])
  setupTimeMinutes         Int?
  equipmentIncluded        Boolean            @default(false)
  overtimeRatePerHour      Float?

  // PHOTO_VIDEO
  styleTags                String[]           @default([])
  deliveryTimelineDays     Int?
  editedPhotosCount        Int?
  travelFeePolicy          String?
  rawFilesIncluded         Boolean            @default(false)

  // FLORIST_DECOR
  floristStyleTags         String[]           @default([])
  seasonalCustomFloral     Boolean            @default(false)
  floristSetupIncluded     Boolean            @default(false)
  rentalItemsAvailable     Boolean            @default(false)

  // Scheduling
  operatingDays            String[]           @default(["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"])
  leadTimeDays             Int                @default(7)

  // Stats
  totalBookings            Int                @default(0)
  completedBookings        Int                @default(0)
  averageRating            Float              @default(0)
  totalReviews             Int                @default(0)
  responseRate             Float              @default(0)
  responseTimeHours        Float?

  // Timestamps
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  // Relations
  packages                 Package[]
  addOns                   AddOn[]
  availabilityBlocks       AvailabilityBlock[]
  eventRequests            EventRequest[]
  portfolioItems           PortfolioItem[]
  menuItems                MenuItem[]
  quotes                   Quote[]
  bookings                 Booking[]
  cuisineTypes             CuisineType[]
  eventThemes              EventTheme[]
  equipmentOfferings       Equipment[]
  availability             Availability[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([averageRating])
  @@index([providerTypes])
  @@index([primaryType])
  @@index([isSoloWorker])
  @@index([serviceAreas])
  @@index([minGuestCount])
  @@index([maxGuestCount])
  @@index([averageRating, totalReviews])
}

// PriceType kept — orphaned from Service, safe to leave; removing requires
// an explicit DROP TYPE which is out of scope for this migration.
enum PriceType {
  FLAT_RATE
  PER_PERSON
  PER_HOUR
  CUSTOM
}

// ============================================
// PACKAGE PRICING ENGINE
// ============================================

enum PricingModel {
  PER_PERSON
  FLAT_RATE
  PER_HOUR
  FLAT_PLUS_PER_PERSON
}

enum AddOnPricingType {
  FLAT
  PER_PERSON
  PER_HOUR
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilityBlockReason {
  BOOKED_EXTERNAL
  CLOSED
  PERSONAL
  MAINTENANCE
}

model Package {
  id                String               @id @default(uuid())
  providerProfileId String
  providerProfile   ProviderProfile      @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  category          String               // canonical category string per vendor type
  eventTypes        EventType[]
  pricingModel      PricingModel
  basePrice         Float
  minimumSpend      Float?
  minGuests         Int?
  maxGuests         Int?
  durationHours     Float?
  flatFee           Float?               // flat room/base fee for FLAT_PLUS_PER_PERSON
  weekdayPrice      Float?
  weekendPrice      Float?
  imageUrl          String?              // Cloudinary URL for package hero image
  included          String[]
  isActive          Boolean              @default(true)
  sortOrder         Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  seasonalRules     SeasonalPricingRule[]
  dayOfWeekRules    DayOfWeekPricingRule[]
  addOns            AddOn[]              @relation("PackageAddOns")

  // Back-relations required by FK sides declared on EventRequest, Quote, Booking
  eventRequests     EventRequest[]
  quotes            Quote[]
  bookings          Booking[]

  @@index([providerProfileId])
  @@index([isActive])
  @@index([category])
  @@index([pricingModel])
}

model SeasonalPricingRule {
  id                   String   @id @default(uuid())
  packageId            String
  package              Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name                 String   // e.g. "High Season", "Low Season", "Holiday Period"
  startMonth           Int      // 1–12
  startDay             Int      // 1–31
  endMonth             Int      // 1–12
  endDay               Int      // 1–31
  priceOverride        Float?   // replaces basePrice for this period
  minimumSpendOverride Float?   // replaces minimumSpend for this period
  multiplier           Float?   // e.g. 1.25 = 25 % more expensive

  @@index([packageId])
}

model DayOfWeekPricingRule {
  id                   String      @id @default(uuid())
  packageId            String
  package              Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  days                 DayOfWeek[]
  priceOverride        Float?
  minimumSpendOverride Float?

  @@index([packageId])
}

model AddOn {
  id                 String           @id @default(uuid())
  providerProfileId  String
  providerProfile    ProviderProfile  @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  pricingType        AddOnPricingType
  price              Float
  minimumSpend       Float?
  isRequired         Boolean          @default(false)
  isActive           Boolean          @default(true)
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  applicablePackages Package[]        @relation("PackageAddOns")

  @@index([providerProfileId])
  @@index([isActive])
}

model AvailabilityBlock {
  id                String                  @id @default(uuid())
  providerProfileId String
  providerProfile   ProviderProfile         @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)
  startDate         DateTime
  endDate           DateTime
  reason            AvailabilityBlockReason
  note              String?
  createdAt         DateTime                @default(now())

  @@index([providerProfileId])
  @@index([startDate, endDate])
}

// ============================================
// PORTFOLIO & MEDIA  (unchanged)
// ============================================

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

model PortfolioItem {
  id           String          @id @default(uuid())
  providerId   String
  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title        String
  description  String?         @db.Text
  mediaType    MediaType
  mediaUrl     String
  thumbnailUrl String?
  duration     Int?
  eventType    String?
  guestCount   Int?
  eventDate    DateTime?
  displayOrder Int             @default(0)
  isFeatured   Boolean         @default(false)
  isPublic     Boolean         @default(true)
  viewCount    Int             @default(0)
  likeCount    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tags         PortfolioTag[]

  @@index([providerId])
  @@index([mediaType])
  @@index([isFeatured])
}

model PortfolioTag {
  id             String          @id @default(uuid())
  name           String
  portfolioItems PortfolioItem[]

  @@unique([name])
}

// ============================================
// CUISINE & THEMES
// (back-relations to EventRequest removed — new EventRequest is
//  vendor-direct and does not carry cuisine/theme preferences)
// ============================================

model CuisineType {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  iconUrl     String?
  providers   ProviderProfile[]
}

model EventTheme {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  iconUrl     String?
  providers   ProviderProfile[]
}

// ============================================
// EQUIPMENT
// (back-relation to EventRequest removed — new EventRequest does
//  not carry equipment preferences)
// ============================================

enum EquipmentCategory {
  PLATING
  SERVING
  COOKING
  DISPLAY
  FURNITURE
  LIGHTING
  AUDIO
  OTHER
}

model Equipment {
  id          String            @id @default(uuid())
  providerId  String
  provider    ProviderProfile   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    EquipmentCategory
  imageUrl    String?
  rentalPrice Float?
  isIncluded  Boolean           @default(false)
  createdAt   DateTime          @default(now())

  @@index([providerId])
  @@index([category])
}

// ============================================
// EVENTS  (top-level planning object — groups multiple vendor requests)
// ============================================

enum EventStatus {
  PLANNING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Event {
  id          String         @id @default(uuid())
  clientId    String
  client      User           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String         // e.g. "Sarah & John's Wedding"
  eventType   EventType
  eventDate   DateTime
  guestCount  Int
  notes       String?
  status      EventStatus    @default(PLANNING)
  requests    EventRequest[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([clientId])
  @@index([eventDate])
  @@index([status])
}

// ============================================
// EVENT REQUESTS  (redesigned)
// ============================================

enum EventRequestStatus {
  PENDING
  QUOTE_SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum EventType {
  CORPORATE
  WEDDING
  BIRTHDAY
  ANNIVERSARY
  GRADUATION
  BABY_SHOWER
  BRIDAL_SHOWER
  HOLIDAY
  COCKTAIL_PARTY
  DINNER_PARTY
  BRUNCH
  BBQ
  PICNIC
  SOCIAL
  OTHER
}

// ServiceStyle kept — was only used by old EventRequest; orphaned but
// safe to leave; removing requires an explicit DROP TYPE.
enum ServiceStyle {
  BUFFET
  PLATED
  FAMILY_STYLE
  FOOD_STATIONS
  COCKTAIL
  DROP_OFF
  FOOD_TRUCK
  CUSTOM
}

model EventRequest {
  id                 String             @id @default(uuid())
  clientId           String
  client             User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  eventId            String?
  event              Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  providerProfileId  String
  providerProfile    ProviderProfile    @relation(fields: [providerProfileId], references: [id])
  packageId          String?
  package            Package?           @relation(fields: [packageId], references: [id])
  eventType          EventType
  eventDate          DateTime
  guestCount         Int
  durationHours      Float?
  selectedAddOnIds   String[]
  specialRequests    String?
  calculatedEstimate Float?
  isOutOfParameters  Boolean            @default(false)
  status             EventRequestStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  quotes             Quote[]

  @@index([clientId])
  @@index([eventId])
  @@index([providerProfileId])
  @@index([status])
  @@index([eventDate])
  @@index([packageId])
}

// ============================================
// QUOTES  (redesigned)
// ============================================

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

model Quote {
  id                 String          @id @default(uuid())
  eventRequestId     String
  eventRequest       EventRequest    @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)
  providerProfileId  String
  providerProfile    ProviderProfile @relation(fields: [providerProfileId], references: [id])
  packageId          String?
  package            Package?        @relation(fields: [packageId], references: [id])
  version            Int             @default(1)
  eventDate          DateTime
  guestCount         Int
  durationHours      Float?
  packagePrice       Float
  minimumSpend       Float?
  addOns             Json            // [{addOnId, name, pricingType, price, quantity, total}]
  addOnsTotal        Float           @default(0)
  adjustments        Json            // [{description, amount}] — negative for discounts
  adjustmentsTotal   Float           @default(0)
  subtotal           Float
  tax                Float
  total              Float
  depositAmount      Float
  isAutoGenerated    Boolean         @default(false)
  isOutOfParameters  Boolean         @default(false)
  vendorMessage      String?
  expiresAt          DateTime?
  status             QuoteStatus     @default(DRAFT)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  booking            Booking?

  @@index([eventRequestId])
  @@index([providerProfileId])
  @@index([packageId])
  @@index([status])
}

// ============================================
// BOOKINGS  (redesigned)
// ============================================

enum BookingStatus {
  PENDING_DEPOSIT
  DEPOSIT_PAID
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
  PENDING_REVIEW    // out-of-parameter bookings awaiting vendor confirmation
}

model Booking {
  id                String          @id @default(uuid())
  clientId          String
  client            User            @relation("ClientBookings", fields: [clientId], references: [id])
  providerProfileId String
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id])
  packageId         String
  package           Package         @relation(fields: [packageId], references: [id])
  quoteId           String          @unique
  quote             Quote           @relation(fields: [quoteId], references: [id])
  eventType         EventType
  eventDate         DateTime
  guestCount        Int
  durationHours     Float?
  packagePrice      Float
  addOnsTotal       Float
  adjustmentsTotal  Float
  subtotal          Float
  tax               Float
  total             Float
  depositAmount     Float
  depositPaidAt     DateTime?
  status            BookingStatus   @default(PENDING_DEPOSIT)
  vendorNotes       String?
  specialRequests   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Back-relations for models kept unchanged
  payments          Payment[]
  review            Review?

  @@index([clientId])
  @@index([providerProfileId])
  @@index([packageId])
  @@index([status])
  @@index([eventDate])
  @@index([providerProfileId, status])
  @@index([clientId, status])
  @@index([status, eventDate])
}

// ============================================
// PAYMENTS  (unchanged — back-relation to Booking preserved)
// ============================================

enum PaymentType {
  DEPOSIT
  BALANCE
  REFUND
  TIP
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id               String        @id @default(uuid())
  bookingId        String
  booking          Booking       @relation(fields: [bookingId], references: [id])
  type             PaymentType
  status           PaymentStatus @default(PENDING)
  amount           Float
  currency         String        @default("USD")
  stripePaymentId  String?
  stripeCustomerId String?
  cardLast4        String?
  cardBrand        String?
  createdAt        DateTime      @default(now())
  completedAt      DateTime?

  @@index([bookingId])
  @@index([status])
}

// ============================================
// REVIEWS  (unchanged — back-relation to Booking preserved)
// ============================================

model Review {
  id                  String    @id @default(uuid())
  bookingId           String    @unique
  booking             Booking   @relation(fields: [bookingId], references: [id])
  authorId            String
  author              User      @relation("ReviewAuthor", fields: [authorId], references: [id])
  subjectId           String
  subject             User      @relation("ReviewSubject", fields: [subjectId], references: [id])
  overallRating       Float
  foodQuality         Float?
  presentation        Float?
  punctuality         Float?
  communication       Float?
  valueForMoney       Float?
  title               String?
  content             String    @db.Text
  photoUrls           String[]
  providerResponse    String?   @db.Text
  providerRespondedAt DateTime?
  isPublic            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([subjectId])
  @@index([overallRating])
  @@index([subjectId, isPublic])
  @@index([isPublic, overallRating])
}

// ============================================
// MESSAGING  (unchanged)
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  participants  String[]
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  messages      Message[]

  @@index([participants])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  recipientId    String
  recipient      User         @relation("MessageRecipient", fields: [recipientId], references: [id])
  content        String       @db.Text
  attachmentUrls String[]
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
}

// ============================================
// NOTIFICATIONS  (unchanged)
// ============================================

enum NotificationType {
  NEW_REQUEST
  NEW_QUOTE
  QUOTE_ACCEPTED
  QUOTE_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  NEW_MESSAGE
  NEW_REVIEW
  REMINDER
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================
// FAVORITES  (unchanged)
// ============================================

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
  @@index([userId])
}

// ============================================
// AVAILABILITY  (unchanged — legacy day-level blocking; AvailabilityBlock
//  provides the new date-range blocking model alongside this)
// ============================================

model Availability {
  id          String          @id @default(uuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  date        DateTime        @db.Date
  isAvailable Boolean         @default(true)
  notes       String?

  @@unique([providerId, date])
  @@index([providerId])
  @@index([date])
}

// ============================================
// MENU ITEMS  (unchanged)
// ============================================

model MenuItem {
  id           String                @id @default(uuid())
  providerId   String
  provider     ProviderProfile       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name         String
  description  String?               @db.Text
  category     String
  price        Float
  pricingTiers MenuItemPricingTier[]
  imageUrl     String?
  isAvailable  Boolean               @default(true)
  displayOrder Int                   @default(0)
  allergens    String[]
  dietaryInfo  String[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([providerId])
  @@index([category])
  @@index([isAvailable])
}

model MenuItemPricingTier {
  id           String   @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  minQuantity  Int
  maxQuantity  Int?
  pricePerUnit Float
  createdAt    DateTime @default(now())

  @@index([menuItemId])
  @@index([minQuantity])
}
